{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MD Viewer",
  "version": "1.0.2",
  "identifier": "com.wassupbro.mdviewer",
  "build": {
    "frontendDist": "../renderer",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "MD Viewer",
        "width": 1100,
        "height": 720,
        "minWidth": 680,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdx", "txt"],
        "name": "Markdown Document",
        "description": "Markdown text file",
        "role": "Viewer"
      }
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "displayLanguageSelector": false
      }
    }
  }
}
